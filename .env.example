# Media Cloud API Key (get from https://search.mediacloud.org/)
MEDIACLOUD_API_KEY=your_api_key_here

# Search Configuration
SEARCH_QUERIES=international relations,global economy,technology,climate change,geopolitics,AI,trade war,shenyang,沈阳
GOOGLE_NEWS_QUERIES=world news,global politics,breaking news,international trade,shenyang,沈阳

# Fetch Intervals (minutes)
MEDIACLOUD_INTERVAL=360
GOOGLE_NEWS_INTERVAL=120
GDELT_INTERVAL=60
ANALYSIS_INTERVAL=180

# Server
HOST=0.0.0.0
PORT=8000
